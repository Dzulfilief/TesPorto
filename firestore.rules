rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is the admin
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'jowosantae@gmail.com';
    }

    // Helper to validate IDs
    function isValidId(id) {
      return id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Projects schema validation helper
    function isValidProject(data) {
      return data.keys().hasAll(['title', 'description', 'category', 'createdAt'])
        && data.title is string && data.title.size() > 0 && data.title.size() <= 200
        && data.description is string && data.description.size() > 0 && data.description.size() <= 2000
        && data.category is string && data.category.size() > 0 && data.category.size() <= 100
        && data.createdAt is int;
    }

    // Profile schema validation helper
    function isValidProfile(data) {
      return data.keys().hasAll(['name', 'title', 'aboutMe'])
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.title is string && data.title.size() > 0 && data.title.size() <= 100
        && data.aboutMe is string && data.aboutMe.size() > 0 && data.aboutMe.size() <= 2000;
    }

    // Match projects
    match /projects/{projectId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(projectId) && isValidProject(request.resource.data);
      allow update: if isAdmin() && isValidId(projectId) && isValidProject(request.resource.data);
      allow delete: if isAdmin() && isValidId(projectId);
    }

    // Match profile settings
    match /profile/{docId} {
      allow read: if true;
      allow create, update: if isAdmin() && docId == 'settings' && isValidProfile(request.resource.data);
      allow delete: if isAdmin() && docId == 'settings';
    }
  }
}
